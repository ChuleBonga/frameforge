NVIDIA_VIDEO_ENDPOINT=https://ai.api.nvidia.com/v1/genai/stabilityai/stable-video-diffusion

LOCAL_COMFY_BASE_URL=http://127.0.0.1:8188
LOCAL_COMFY_WORKFLOW_PATH=workflows/svd-image-to-video.json
